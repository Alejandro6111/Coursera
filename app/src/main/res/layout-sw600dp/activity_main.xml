<?xml version="1.0" encoding="utf-8"?>
<!-- Layout optimizado para tablets (600dp y superior de ancho mínimo) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background"
    android:gravity="center"
    android:padding="@dimen/padding_large">

    <!-- Espaciador superior -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Contenedor central -->
    <LinearLayout
        android:layout_width="500dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Título -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            style="@style/TitleText"
            android:gravity="center"
            android:textSize="32sp"
            android:layout_marginBottom="@dimen/padding_large" />

        <!-- Mensaje -->
        <TextView
            android:id="@+id/message_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/welcome_message"
            style="@style/MessageText"
            android:gravity="center"
            android:textSize="18sp"
            android:layout_marginBottom="@dimen/padding_large"
            android:lineSpacingMultiplier="1.3" />

        <!-- Imagen más grande para tablets -->
        <ImageView
            android:id="@+id/android_mascot"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:contentDescription="@string/android_mascot"
            android:scaleType="centerInside"
            android:src="@drawable/android_cute"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/padding_large" />

        <!-- Información adicional -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/language_spanish"
            style="@style/MessageText"
            android:gravity="center"
            android:layout_marginTop="@dimen/padding_medium" />

    </LinearLayout>

    <!-- Espaciador inferior -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
